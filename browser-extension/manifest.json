{
  "manifest_version": 3,
  "name": "WikiCitationFixer",
  "version": "3.0.0",
  "description": "Fix Wikipedia citations — expand, clean up, enrich identifiers, and more",
  "permissions": ["storage"],
  "host_permissions": [
    "https://*.wikipedia.org/wiki/*",
    "https://*.wikimedia.org/*"
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "WikiCitationFixer"
  },
  "content_scripts": [
    {
      "matches": ["https://*.wikipedia.org/wiki/*"],
      "js": ["browser-polyfill.js", "content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icon.svg",
    "48": "icon.svg",
    "128": "icon.svg"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "wikifix@wolren.dev",
      "strict_min_version": "115.0"
    }
  }
}
