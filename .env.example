# API keys for higher rate limits.
# Copy this file to .env and fill in your keys.
# Usage: python -m wikifix --env .env

# NCBI API key — https://ncbi.nlm.nih.gov/account/
# Without key:  3 req/s
# With key:    10 req/s
NCBI_API_KEY=

# Semantic Scholar API key — https://api.semanticscholar.org/
# Without key:  ~1 req/s (estimated)
# With key:    10 req/s
SEMANTIC_SCHOLAR_API_KEY=

# Email for CrossRef polite pool — https://github.com/CrossRef/rest-api-doc#good-manners
# With email:  preferred access pool
CROSSREF_EMAIL=
